# =============================================================================
# replit — local environment template
#
# Copy to .env and fill in your values:
#     cp .env.example .env
#
# This file IS committed; .env is not.
# Variables here are read by docker-compose.yml and the Makefile.
# =============================================================================

# ---- Docker Hub publishing -------------------------------------------------
# Your Docker Hub namespace. Used by the Makefile + docker-compose.published.yml.
DH_USER=suraim001

# Set to true to make `make up` pull images from Docker Hub instead of building.
# (Requires the three images to be published first — see README "Publishing".)
DH_USE_HUB=false

# ---- Host Docker socket group ---------------------------------------------
# gid of the host's `docker` group. On Linux:
#     stat -c '%g' /var/run/docker.sock
# On macOS / Windows this is irrelevant (Docker Desktop handles perms).
DOCKER_GID=1002

# ---- Frontend --------------------------------------------------------------
# Port the Vite dev server (or nginx) listens on the host.
FRONTEND_PORT=5173

# ---- Backend ---------------------------------------------------------------
# Port the orchestrator API listens on the host.
BACKEND_PORT=3001

# ---- Sandbox image (advanced) ---------------------------------------------
# Override which image is used for new sandbox containers. Default is
# replit-sandbox:latest; when DH_USE_HUB=true this becomes
# ${DH_USER}/replit-sandbox:latest.
SANDBOX_IMAGE=replit-sandbox:latest

# ---- Auth (optional, future) ----------------------------------------------
# REPLIT_JWT_SECRET=
